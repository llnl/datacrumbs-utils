#define DATACRUMBS_UTILS_INSTALL_PREFIX "@DATACRUMBS_UTILS_INSTALL_PREFIX@"
#define DATACRUMBS_UTILS_INSTALL_BIN_DIR "@DATACRUMBS_UTILS_INSTALL_BIN_DIR@"
#define DATACRUMBS_UTILS_INSTALL_SBIN_DIR "@DATACRUMBS_UTILS_INSTALL_SBIN_DIR@"
#define DATACRUMBS_UTILS_INSTALL_LIB_DIR "@DATACRUMBS_UTILS_INSTALL_LIB_DIR@"
#define DATACRUMBS_UTILS_INSTALL_LIBEXEC_DIR "@DATACRUMBS_UTILS_INSTALL_LIBEXEC_DIR@"
#define DATACRUMBS_UTILS_INSTALL_ETC_DIR "@DATACRUMBS_UTILS_INSTALL_ETC_DIR@"
#define DATACRUMBS_UTILS_INSTALL_SHARE_DIR "@DATACRUMBS_UTILS_INSTALL_SHARE_DIR@"
#define DATACRUMBS_UTILS_INSTALL_DATA_DIR "@DATACRUMBS_UTILS_INSTALL_DATA_DIR@"
#define DATACRUMBS_UTILS_INSTALL_MODULES_DIR "@DATACRUMBS_UTILS_INSTALL_MODULES_DIR@"

#endif  // DATACRUMBS_UTILS_CONFIG_HPP
