#!/bin/bash

function usage() {
	echo "Usage: $0 [SBATCH_OPTIONS] [--datacrumbs-enable --datacrumbs-probe-file PATH] script [script args]"
	echo ""
	echo "Datacrumbs sbatch wrapper - adds datacrumbs metadata to enable Datacrumbs"
	echo ""
	echo "DATACRUMBS-SPECIFIC OPTIONS:"
	echo "  --datacrumbs-enable             Enable datacrumbs tracking"
	echo "  --datacrumbs-probe-file PATH    Signed probes json.gz file for runtime tracing"
	echo ""
	echo "NOTE"
	echo "  * The --comment flag is reserved for internal use"
	echo ""
	echo "EXAMPLES:"
	echo "  $0 my-job.sh"
	echo "  $0 --datacrumbs-enable --datacrumbs-probe-file /path/to/probes.json.gz my-job.sh"
	echo "  $0 --datacrumbs-enable --datacrumbs-probe-file /path/to/probes.json.gz -N 2 my-job.sh arg1"
	echo ""
	echo "For comprehensive SLURM options, run: sbatch -h"
	exit 1
}

source @DATACRUMBS_INSTALL_BINARYDIR@/datacrumbs_setup

DATACRUMBS_DRY_RUN=${DATACRUMBS_INPUT_DRY_RUN:-"no"}
if [[ ${DATACRUMBS_DRY_RUN} == "yes" ]]; then
	warn_user "Dry run enabled"
fi

DATACRUMBS_ARGS=()
USER_ENABLE="no"
USER_PROBE_FILE=""

while [[ $# -gt 0 ]]; do
	case "$1" in
	--comment)
		error "The system has disabled comments feature"
		exit 1
		;;
	--datacrumbs-probe-file)
		if [[ $# -lt 2 ]]; then
			error "--datacrumbs-probe-file requires a path"
			exit 1
		fi
		USER_PROBE_FILE="$2"
		shift 2
		;;
	--datacrumbs-enable)
		USER_ENABLE="yes"
		shift 1
		;;
	--)
		shift
		break
		;;
	-h | --help) usage ;;
	*)
		DATACRUMBS_ARGS+=("$1")
		shift
		;;
	esac
done
DATACRUMBS_ARGS+=("$@")

if [[ "${USER_ENABLE}" == "yes" && -z "${USER_PROBE_FILE}" ]]; then
	error "--datacrumbs-probe-file is required when --datacrumbs-enable is set"
	exit 1
fi

if [[ -n "${USER_PROBE_FILE}" && ! -f "${USER_PROBE_FILE}" ]]; then
	error "Probe file does not exist: ${USER_PROBE_FILE}"
	exit 1
fi

DATACRUMBS_INPUTS=$(jq -n -c \
	--arg enable "${USER_ENABLE}" \
	--arg probe_file "${USER_PROBE_FILE}" \
	'{datacrumbs: {enable: $enable, probe_file: $probe_file}}')
echo "${DATACRUMBS_INPUTS}" | jq . || {
	error "Invalid JSON: ${DATACRUMBS_INPUTS}"
	exit 1
}

DATACRUMBS_ARGS+=(--comment "${DATACRUMBS_INPUTS}")

info "Datacrumbs inputs: ${DATACRUMBS_INPUTS}"
info "Datacrumbs args: ${DATACRUMBS_ARGS[*]}"
if [[ ${DATACRUMBS_DRY_RUN} == "yes" ]]; then
	info "Dry run enabled, exiting before sbatch"
	info "sbatch ${DATACRUMBS_ARGS[*]}"
	exit 0
fi

info "sbatch ${DATACRUMBS_ARGS[*]}"
exec sbatch "${DATACRUMBS_ARGS[@]}"
