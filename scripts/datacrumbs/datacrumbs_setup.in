#! /usr/bin/env bash

if [[ "${DATACRUMBS_UTILS_SETUP_LOADED:-0}" == "1" ]]; then
	return 0 2>/dev/null || exit 0
fi
readonly DATACRUMBS_UTILS_SETUP_LOADED=1

SCRIPT_DIR=@DATACRUMBS_INSTALL_BINARYDIR@

source "${SCRIPT_DIR}/datacrumbs_utility"

dc_export_once() {
	local var_name="$1"
	local var_value="$2"
	if [[ -v "${var_name}" ]]; then
		return 0
	fi
	printf -v "${var_name}" '%s' "${var_value}"
	export "${var_name}"
}

if [[ "$(id -u)" != "0" ]]; then
	dc_export_once DATACRUMBS_IS_ROOT 0
	dc_export_once DATACRUMBS_USER "$(id -un)"
else
	dc_export_once DATACRUMBS_IS_ROOT 1
	dc_export_once DATACRUMBS_USER "${SUDO_USER:-${USER:-root}}"
fi

# Version
dc_export_once DATACRUMBS_VERSION "@DATACRUMBS_UTILS_RELEASE_VERSION_STRING@"
dc_export_once DATACRUMBS_LIB_VERSION "@DATACRUMBS_UTILS_PACKAGE_VERSION@"

# Installed datacrumbs core
dc_export_once DATACRUMBS_INSTALL_HOST "@DATACRUMBS_HOST@"
dc_export_once DATACRUMBS_INSTALL_USER "@DATACRUMBS_INSTALL_USER@"
dc_export_once DATACRUMBS_INSTALL_PREFIX "@DATACRUMBS_INSTALL_DIR@"
dc_export_once DATACRUMBS_INSTALL_BIN_DIR "@datacrumbs_INSTALL_BINARYDIR@"
dc_export_once DATACRUMBS_INSTALL_SBIN_DIR "@datacrumbs_INSTALL_SBINARYDIR@"
dc_export_once DATACRUMBS_INSTALL_LIB_DIR "@datacrumbs_INSTALL_LIB_DIR@"
dc_export_once DATACRUMBS_INSTALL_LIBEXEC_DIR "@DATACRUMBS_INSTALL_DIR@/@CMAKE_INSTALL_LIBEXECDIR@/datacrumbs"
dc_export_once DATACRUMBS_INSTALL_ETC_DIR "@datacrumbs_INSTALL_SYSCONFDIR@"
dc_export_once DATACRUMBS_INSTALL_CONFIGS_DIR "@DATACRUMBS_INSTALL_CONFIGS_DIR@"
dc_export_once DATACRUMBS_INSTALL_DATA_DIR "@DATACRUMBS_INSTALL_DATA_DIR@"
dc_export_once DATACRUMBS_PROBE_SECRET_FILE "@DATACRUMBS_PROBE_SECRET_FILE@"
dc_export_once DATACRUMBS_SIGN_PROBES_SOCKET_PATH "@DATACRUMBS_SIGN_PROBES_SOCKET_PATH@"
dc_export_once DATACRUMBS_DISABLE_PROBE_SIGNING "@DATACRUMBS_DISABLE_PROBE_SIGNING@"
dc_export_once DATACRUMBS_INSTALL_MODULES_DIR "@DATACRUMBS_INSTALL_DIR@/@CMAKE_INSTALL_SYSCONFDIR@/datacrumbs/@CMAKE_INSTALL_MODULES_DIR@"
dc_export_once DATACRUMBS_INSTALL_PROBE_OBJECTS_DIR "${DATACRUMBS_INSTALL_LIBEXEC_DIR}/objects"
dc_export_once DATACRUMBS_INSTALL_COMPOSABLE_DIR "${DATACRUMBS_INSTALL_LIBEXEC_DIR}/composable"
dc_export_once DATACRUMBS_INSTALL_COMPOSE_BIN "${DATACRUMBS_INSTALL_LIBEXEC_DIR}/@CMAKE_INSTALL_SBINDIR@/${DATACRUMBS_INSTALL_USER}"
dc_export_once DATACRUMBS_INSTALL_RUNSTATEDIR "@DATACRUMBS_INSTALL_RUNSTATEDIR@"

# Installed datacrumbs-utils
dc_export_once DATACRUMBS_UTILS_INSTALL_PREFIX "@CMAKE_INSTALL_PREFIX@"
dc_export_once DATACRUMBS_UTILS_INSTALL_BIN_DIR "@CMAKE_INSTALL_PREFIX@/@CMAKE_INSTALL_BINDIR@"
dc_export_once DATACRUMBS_UTILS_INSTALL_SBIN_DIR "@CMAKE_INSTALL_PREFIX@/@CMAKE_INSTALL_SBINDIR@"
dc_export_once DATACRUMBS_UTILS_INSTALL_LIB_DIR "@CMAKE_INSTALL_PREFIX@/@CMAKE_INSTALL_LIBDIR@"
dc_export_once DATACRUMBS_UTILS_INSTALL_LIBEXEC_DIR "@CMAKE_INSTALL_PREFIX@/@CMAKE_INSTALL_LIBEXECDIR@/@PROJECT_NAME@"
dc_export_once DATACRUMBS_UTILS_INSTALL_ETC_DIR "@CMAKE_INSTALL_PREFIX@/@CMAKE_INSTALL_SYSCONFDIR@/@PROJECT_NAME@"
dc_export_once DATACRUMBS_UTILS_INSTALL_SHARE_DIR "@CMAKE_INSTALL_PREFIX@/share/datacrumbs"
dc_export_once DATACRUMBS_UTILS_INSTALL_DATA_DIR "${DATACRUMBS_UTILS_INSTALL_SHARE_DIR}/data"
dc_export_once DATACRUMBS_UTILS_INSTALL_MODULES_DIR "${DATACRUMBS_UTILS_INSTALL_ETC_DIR}/@CMAKE_INSTALL_MODULES_DIR@"
dc_export_once DATACRUMBS_MODULEPATH "${DATACRUMBS_INSTALL_MODULES_DIR}:${DATACRUMBS_UTILS_INSTALL_MODULES_DIR}"

dc_prepend_path() {
	local var_name="$1"
	local path_value="$2"
	local current_value="${!var_name-}"
	if [[ -z "${path_value}" ]]; then
		return 0
	fi
	case ":${current_value}:" in
	*:"${path_value}":*) ;;
	*)
		if [[ -n "${current_value}" ]]; then
			printf -v "${var_name}" '%s:%s' "${path_value}" "${current_value}"
		else
			printf -v "${var_name}" '%s' "${path_value}"
		fi
		export "${var_name}"
		;;
	esac
}

dc_prepend_path MODULEPATH "${DATACRUMBS_UTILS_INSTALL_MODULES_DIR}"
dc_prepend_path MODULEPATH "${DATACRUMBS_INSTALL_MODULES_DIR}"

if declare -F module >/dev/null 2>&1; then
	module use "${DATACRUMBS_INSTALL_MODULES_DIR}" >/dev/null 2>&1 || true
	module use "${DATACRUMBS_UTILS_INSTALL_MODULES_DIR}" >/dev/null 2>&1 || true
fi

# Client and wrapper helpers. The client library is installed with datacrumbs.
dc_export_once DATACRUMBS_CLIENT_LIB "${DATACRUMBS_INSTALL_LIB_DIR}/libdatacrumbs_client.so"
dc_export_once DATACRUMBS_CLIENT_BIN "${DATACRUMBS_INSTALL_LIBEXEC_DIR}/@CMAKE_INSTALL_SBINDIR@/${DATACRUMBS_USER}"

# Trace
dc_export_once DATACRUMBS_TRACE_DIR_PATTERN "@DATACRUMBS_CONFIGURED_TRACE_DIR@/%YY%/%MM%/%DD%"

# Job
dc_export_once DATACRUMBS_JOB_SCHEDULER "@DATACRUMBS_SCHEDULER_TYPE@"
dc_export_once DATACRUMBS_JOB_ID_VAR "@DATACRUMBS_SCHEDULER_JOBID_ENV_VAR@"

# Server
dc_export_once DATACRUMBS_SERVER_LOAD_TIMEOUT "${DATACRUMBS_SERVER_TIMEOUT_USER:-600}"
dc_export_once DATACRUMBS_SERVER_RUN_DIR "@DATACRUMBS_INSTALL_RUNSTATEDIR@/datacrumbs"
dc_export_once DATACRUMBS_SERVER_RUN_ID_FILE "${DATACRUMBS_SERVER_RUN_DIR}/datacrumbs.runid"
dc_export_once DATACRUMBS_SERVER_RUN_ID "$(
	job_id_value="${!DATACRUMBS_JOB_ID_VAR-}"
	if [[ -z "${job_id_value}" ]]; then
		if [[ -f "${DATACRUMBS_SERVER_RUN_ID_FILE}" ]]; then
			cat "${DATACRUMBS_SERVER_RUN_ID_FILE}" 2>/dev/null
		else
			date +"%Y%m%d%H%M%S"
		fi
	else
		echo "${job_id_value}"
	fi
)"
dc_export_once DATACRUMBS_SERVER_PID_FILE "${DATACRUMBS_SERVER_RUN_DIR}/datacrumbs-${DATACRUMBS_SERVER_RUN_ID}.pid"
dc_export_once DATACRUMBS_SERVER_SYSTEMD_PID_FILE "${DATACRUMBS_SERVER_RUN_DIR}/datacrumbs-systemd-${DATACRUMBS_SERVER_RUN_ID}.pid"
dc_export_once DATACRUMBS_SERVER_READY_FILE "${DATACRUMBS_SERVER_RUN_DIR}/datacrumbs-${DATACRUMBS_SERVER_RUN_ID}.ready"
dc_export_once DATACRUMBS_SERVER_STATUS_FILE "${DATACRUMBS_SERVER_RUN_DIR}/datacrumbs-${DATACRUMBS_SERVER_RUN_ID}.json"
dc_export_once DATACRUMBS_SERVER_ENV_FILE "${DATACRUMBS_SERVER_RUN_DIR}/datacrumbs-${DATACRUMBS_SERVER_RUN_ID}.env"
dc_export_once DATACRUMBS_SERVER_MODULE 0
dc_export_once DATACRUMBS_SERVER_PREAMBLE ""

# Log
dc_export_once DATACRUMBS_LOG_DIR "@DATACRUMBS_CONFIGURED_LOG_DIR@"
dc_export_once DATACRUMBS_LOG_FILE "${DATACRUMBS_LOG_DIR}/datacrumbs_${DATACRUMBS_USER}_${DATACRUMBS_SERVER_RUN_ID}.log"

readonly DATACRUMBS_IS_ROOT
readonly DATACRUMBS_USER
readonly DATACRUMBS_VERSION
readonly DATACRUMBS_LIB_VERSION
readonly DATACRUMBS_INSTALL_HOST
readonly DATACRUMBS_INSTALL_USER
readonly DATACRUMBS_INSTALL_PREFIX
readonly DATACRUMBS_INSTALL_BIN_DIR
readonly DATACRUMBS_INSTALL_SBIN_DIR
readonly DATACRUMBS_INSTALL_LIB_DIR
readonly DATACRUMBS_INSTALL_LIBEXEC_DIR
readonly DATACRUMBS_INSTALL_ETC_DIR
readonly DATACRUMBS_INSTALL_CONFIGS_DIR
readonly DATACRUMBS_INSTALL_DATA_DIR
readonly DATACRUMBS_PROBE_SECRET_FILE
readonly DATACRUMBS_SIGN_PROBES_SOCKET_PATH
readonly DATACRUMBS_DISABLE_PROBE_SIGNING
readonly DATACRUMBS_INSTALL_MODULES_DIR
readonly DATACRUMBS_INSTALL_PROBE_OBJECTS_DIR
readonly DATACRUMBS_INSTALL_COMPOSABLE_DIR
readonly DATACRUMBS_INSTALL_COMPOSE_BIN
readonly DATACRUMBS_INSTALL_RUNSTATEDIR
readonly DATACRUMBS_UTILS_INSTALL_PREFIX
readonly DATACRUMBS_UTILS_INSTALL_BIN_DIR
readonly DATACRUMBS_UTILS_INSTALL_SBIN_DIR
readonly DATACRUMBS_UTILS_INSTALL_LIB_DIR
readonly DATACRUMBS_UTILS_INSTALL_LIBEXEC_DIR
readonly DATACRUMBS_UTILS_INSTALL_ETC_DIR
readonly DATACRUMBS_UTILS_INSTALL_SHARE_DIR
readonly DATACRUMBS_UTILS_INSTALL_DATA_DIR
readonly DATACRUMBS_UTILS_INSTALL_MODULES_DIR
readonly DATACRUMBS_CLIENT_LIB
readonly DATACRUMBS_CLIENT_BIN
readonly DATACRUMBS_TRACE_DIR_PATTERN
readonly DATACRUMBS_JOB_SCHEDULER
readonly DATACRUMBS_JOB_ID_VAR
readonly DATACRUMBS_SERVER_LOAD_TIMEOUT
readonly DATACRUMBS_SERVER_RUN_DIR
readonly DATACRUMBS_SERVER_RUN_ID_FILE
readonly DATACRUMBS_SERVER_RUN_ID
readonly DATACRUMBS_SERVER_PID_FILE
readonly DATACRUMBS_SERVER_SYSTEMD_PID_FILE
readonly DATACRUMBS_SERVER_READY_FILE
readonly DATACRUMBS_SERVER_STATUS_FILE
readonly DATACRUMBS_SERVER_ENV_FILE
readonly DATACRUMBS_SERVER_MODULE
readonly DATACRUMBS_SERVER_PREAMBLE
readonly DATACRUMBS_LOG_DIR
readonly DATACRUMBS_LOG_FILE
