#! /usr/bin/env bash


PYTHON_SCRIPT="@CMAKE_INSTALL_PREFIX@/@CMAKE_INSTALL_LIBEXECDIR@/@PROJECT_NAME@/python/configure_templates.py"
PYTHON_EXECUTABLE="@DATACRUMBS_UTILS_PYTHON_EXECUTABLE@"
export DATACRUMBS_INSTALL_DIR="@DATACRUMBS_INSTALL_DIR@"

exec "${PYTHON_EXECUTABLE}" "${PYTHON_SCRIPT}" "$@"
