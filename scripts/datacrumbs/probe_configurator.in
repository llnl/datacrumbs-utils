#! /usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="@CMAKE_RUNTIME_OUTPUT_DIRECTORY@"

if [[ -f "$SCRIPT_DIR/datacrumbs_args" ]]; then
	source "$SCRIPT_DIR/datacrumbs_args"
else
	echo "Error: datacrumbs_args not found in $SCRIPT_DIR" >&2
	exit 1
fi

APP="DC_PROBE_CONFIGURATOR"
dc_args_init "$APP"
dc_args_add_positional "$APP" "config-file" "MANDATORY" "Path to the probe configuration YAML file"
dc_args_add_positional "$APP" "output-file" "MANDATORY" "Path to write the signed compressed probes JSON"
dc_args_parse "$APP" "datacrumbs_probe_configurator" "$@"

config_file="${DC_PROBE_CONFIGURATOR_CONFIG_FILE}"
if [[ ! -f "${config_file}" ]]; then
	echo "Error: config file not found: ${config_file}" >&2
	exit 1
fi

config_dir="$(cd "$(dirname "${config_file}")" && pwd)"
config_base="$(basename "${config_file}")"
config_name="${config_base%.*}"
output_path="${DC_PROBE_CONFIGURATOR_OUTPUT_FILE}"
output_dir="$(dirname "${output_path}")"

export DATACRUMBS_USER="${DATACRUMBS_USER:-$(id -un)}"
source "@DATACRUMBS_BUILD_PROJECT_ENV_FILE@"

mkdir -p "${output_dir}"
output_dir="$(cd "${output_dir}" && pwd)"
output_path="${output_dir}/$(basename "${output_path}")"
export LD_LIBRARY_PATH="@CMAKE_LIBRARY_OUTPUT_DIRECTORY@:@DEPENDENCY_LIBRARY_DIRS_COLON@:${LD_LIBRARY_PATH:-}"

cmd=(
	"@DATACRUMBS_PROBE_CONFIGURATOR_BIN@"
	"${config_name}"
	"--config_path" "${config_dir}"
	"--data_dir" "${output_dir}"
	"--probe_file_path" "${output_path}"
	"--user" "${DATACRUMBS_USER}"
)

if [[ "${DRY_RUN:-0}" == "1" ]]; then
	printf "[DRY RUN]"
	printf " %q" "${cmd[@]}"
	printf "\n"
	exit 0
fi

exec "${cmd[@]}"
