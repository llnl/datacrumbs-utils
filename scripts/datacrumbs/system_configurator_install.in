#! /usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="@DATACRUMBS_INSTALL_BINARYDIR@"

if [[ -f "$SCRIPT_DIR/datacrumbs_args" ]]; then
	source "$SCRIPT_DIR/datacrumbs_args"
else
	echo "Error: datacrumbs_args not found in $SCRIPT_DIR" >&2
	exit 1
fi

APP="DC_SYSTEM_CONFIGURATOR"
dc_args_init "$APP"
dc_args_parse "$APP" "datacrumbs_system_configurator" "$@"

config_name="@DATACRUMBS_HOST@"
runtime_user="@DATACRUMBS_INSTALL_USER@"
config_path="@DATACRUMBS_INSTALL_CONFIGS_DIR@"
data_dir="@DATACRUMBS_INSTALL_DATA_SHARE_DIR@"
trace_log_dir="@DATACRUMBS_CONFIGURED_TRACE_DIR@"
log_dir="@DATACRUMBS_CONFIGURED_LOG_DIR@"
disable_mpi="1"

export DATACRUMBS_USER="${runtime_user}"
source "@DATACRUMBS_INSTALL_PROJECT_ENV_FILE@"

mkdir -p "${data_dir}"
export LD_LIBRARY_PATH="@DATACRUMBS_INSTALL_LIB_DIR@:@DEPENDENCY_LIBRARY_DIRS_COLON@:${LD_LIBRARY_PATH:-}"

cmd=(
	"@DATACRUMBS_SYSTEM_CONFIGURATOR_INSTALL_BIN@"
	"${config_name}"
	"--user" "${runtime_user}"
	"--config_path" "${config_path}"
	"--data_dir" "${data_dir}"
	"--trace_log_dir" "${trace_log_dir}"
	"--log_dir" "${log_dir}"
)

if [[ "${disable_mpi}" == "1" ]]; then
	cmd+=("--disable-mpi")
fi

if [[ "${DRY_RUN:-0}" == "1" ]]; then
	printf "[DRY RUN]"
	printf " %q" "${cmd[@]}"
	printf "\n"
	exit 0
fi

exec "${cmd[@]}"
